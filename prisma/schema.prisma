generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tracked TrackedCompany[]

  @@map("users")
}

model Company {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  slug         String        @unique
  description  String?
  website      String?
  logoUrl      String?       @map("logo_url")
  industry     String?
  headquarters String?
  sourceType   CompanySource @default(manual) @map("source_type")
  sourceId     String?       @map("source_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  jobs      Job[]
  trackedBy TrackedCompany[]

  @@map("companies")
}

model Job {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  slug        String    @unique
  description String    @default("")
  type        JobType
  location    String?
  remote      Boolean   @default(false)
  salaryMin   Int?      @map("salary_min")
  salaryMax   Int?      @map("salary_max")
  currency    String    @default("USD")
  url         String?
  status      JobStatus @default(ACTIVE)
  postedAt    DateTime? @map("posted_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  externalJobId String? @map("external_job_id")

  companyId String  @map("company_id") @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  matches Match[]

  @@unique([companyId, externalJobId])
  @@map("jobs")
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE

  @@map("job_type")
}

enum JobStatus {
  ACTIVE
  CLOSED

  @@map("job_status")
}

enum CompanySource {
  greenhouse
  lever
  ashby
  workday
  manual

  @@map("company_source")
}

model TrackedCompany {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  companyId      String    @map("company_id") @db.Uuid
  keywords       String[]
  jobTypes       JobType[] @map("job_types")
  remoteOnly     Boolean?  @map("remote_only")
  locationFilter String?   @map("location_filter")
  emailAlerts    Boolean   @default(true) @map("email_alerts")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  matches Match[]

  @@unique([userId, companyId])
  @@map("tracked_companies")
}

model Match {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trackedCompanyId String    @map("tracked_company_id") @db.Uuid
  jobId            String    @map("job_id") @db.Uuid
  notified         Boolean   @default(false)
  notifiedAt       DateTime? @map("notified_at")
  dismissed        Boolean   @default(false)
  createdAt        DateTime  @default(now()) @map("created_at")

  trackedCompany TrackedCompany @relation(fields: [trackedCompanyId], references: [id], onDelete: Cascade)
  job            Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([trackedCompanyId, jobId])
  @@map("matches")
}
