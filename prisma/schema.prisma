generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String    @id @db.Uuid
  email            String    @unique
  name             String?
  avatarUrl        String?   @map("avatar_url")
  onboardingComplete Boolean   @default(false) @map("onboarding_complete")
  defaultCriteria    Json?     @map("default_criteria")
  alertMode          AlertMode @default(instant) @map("alert_mode")
  alertsPaused       Boolean   @default(false) @map("alerts_paused")
  unsubscribeToken   String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("unsubscribe_token")
  resumeText       String?   @map("resume_text")
  linkedinUrl      String?   @map("linkedin_url")
  currentTitle     String?   @map("current_title")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tracked             TrackedCompany[]
  trackedRoles        TrackedRole[]
  linkedInConnections LinkedInConnection[]

  @@map("users")
}

model TrackedRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, title])
  @@map("tracked_roles")
}

model Company {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  slug         String        @unique
  description  String?
  website      String?
  logoUrl      String?       @map("logo_url")
  industry     String?
  headquarters String?
  size         CompanySize?
  fundingStage FundingStage? @map("funding_stage")
  sourceType   CompanySource @default(manual) @map("source_type")
  sourceId     String?       @map("source_id")
  tags         String[]      @default([])
  blogRssUrl       String?       @map("blog_rss_url")
  recentlyFundedAt DateTime?     @map("recently_funded_at")
  // Earliest date this company's job data is reliable (first ingestion).
  // Trend windows must never reach before this date (+ a read-side buffer
  // to skip the initial bulk-import spike).
  trackingStartedAt DateTime?    @map("tracking_started_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  jobs                Job[]
  trackedBy           TrackedCompany[]
  collections         CollectionCompany[]
  signals             CompanySignal[]
  insights            CompanyInsight[]
  linkedInConnections LinkedInConnection[]
  roleSnapshots       CompanyRoleSnapshot[]

  @@map("companies")
}

// One row per company per day: how many roles were open when the daily
// snapshot cron ran. This is the time-series behind hiring-momentum
// (consumer) and trend analytics (B2B). Append-only via idempotent upsert.
model CompanyRoleSnapshot {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capturedOn     DateTime @map("captured_on") @db.Date
  openRolesTotal Int      @map("open_roles_total")
  createdAt      DateTime @default(now()) @map("created_at")

  companyId String  @map("company_id") @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, capturedOn])
  @@map("company_role_snapshots")
}

model Job {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  slug        String    @unique
  description String    @default("")
  type        JobType
  location    String?
  remote      Boolean   @default(false)
  salaryMin   Int?      @map("salary_min")
  salaryMax   Int?      @map("salary_max")
  currency    String    @default("USD")
  url         String?
  status      JobStatus @default(ACTIVE)
  postedAt    DateTime? @map("posted_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  externalJobId String? @map("external_job_id")

  companyId String  @map("company_id") @db.Uuid
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  matches Match[]

  @@unique([companyId, externalJobId])
  @@map("jobs")
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE

  @@map("job_type")
}

enum JobStatus {
  ACTIVE
  CLOSED

  @@map("job_status")
}

model Collection {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  slug          String   @unique
  description   String?
  coverImageUrl String?  @map("cover_image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  companies CollectionCompany[]

  @@map("collections")
}

model CollectionCompany {
  collectionId String @map("collection_id") @db.Uuid
  companyId    String @map("company_id") @db.Uuid
  displayOrder Int    @default(0) @map("display_order")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([collectionId, companyId])
  @@map("collection_companies")
}

enum ApplicationStatus {
  INTERESTED
  APPLIED
  INTERVIEWING
  REJECTED
  OFFER
  NOT_INTERESTED

  @@map("application_status")
}

enum AlertMode {
  instant
  daily

  @@map("alert_mode")
}

enum CompanySource {
  greenhouse
  lever
  ashby
  gem
  workday
  manual

  @@map("company_source")
}

enum CompanySize {
  startup
  small
  medium
  large
  enterprise

  @@map("company_size")
}

enum FundingStage {
  pre_seed
  seed
  series_a
  series_b
  series_c
  growth
  public

  @@map("funding_stage")
}

model TrackedCompany {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  companyId      String    @map("company_id") @db.Uuid
  keywords       String[]
  jobTypes       JobType[] @map("job_types")
  remoteOnly     Boolean?  @map("remote_only")
  locationFilter String?   @map("location_filter")
  emailAlerts    Boolean   @default(true) @map("email_alerts")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  matches Match[]

  @@unique([userId, companyId])
  @@map("tracked_companies")
}

// ─── Company intelligence signals (blog posts, etc.) ──────────────────────────

enum SignalType {
  blog_post
  news

  @@map("signal_type")
}

model CompanySignal {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String     @map("company_id") @db.Uuid
  type        SignalType @default(blog_post)
  title       String
  url         String?
  summary     String?
  publishedAt DateTime?  @map("published_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, url])
  @@map("company_signals")
}

// ─── Insider content (getting hired guides, etc.) ─────────────────────────────

model CompanyInsight {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  slug        String   @unique
  title       String
  body        String   // markdown
  author      String?
  publishedAt DateTime @default(now()) @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_insights")
}

// ─── Funding signals (from TechCrunch RSS etc.) ──────────────────────────────

enum FundingSignalStatus {
  pending
  approved
  rejected
  added

  @@map("funding_signal_status")
}

model FundingSignal {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName String              @map("company_name")
  website     String?
  amount      String?
  round       String?
  investors   String?
  sourceUrl   String              @unique @map("source_url")
  atsUrl      String?             @map("ats_url")
  atsPlatform String?             @map("ats_platform")
  atsSlug     String?             @map("ats_slug")
  status      FundingSignalStatus @default(pending)
  autoApproved Boolean            @default(false) @map("auto_approved")
  companyId   String?             @map("company_id") @db.Uuid
  detectedAt  DateTime            @default(now()) @map("detected_at")

  @@map("funding_signals")
}

model Match {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trackedCompanyId String            @map("tracked_company_id") @db.Uuid
  jobId            String            @map("job_id") @db.Uuid
  notified         Boolean           @default(false)
  notifiedAt       DateTime?         @map("notified_at")
  dismissed        Boolean           @default(false)
  seenAt           DateTime?         @map("seen_at")
  aiScore          Float?            @map("ai_score")
  applicationStatus ApplicationStatus @default(INTERESTED) @map("application_status")
  applicationNote  String?           @map("application_note")
  appliedAt        DateTime?         @map("applied_at")
  createdAt        DateTime          @default(now()) @map("created_at")

  trackedCompany TrackedCompany @relation(fields: [trackedCompanyId], references: [id], onDelete: Cascade)
  job            Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([trackedCompanyId, jobId])
  @@map("matches")
}

model LinkedInConnection {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  linkedinUrl String?   @map("linkedin_url")
  company     String
  title       String?
  connectedOn DateTime? @map("connected_on")
  companyId   String?   @map("company_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchedCompany Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@map("linkedin_connections")
}
